generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // or mysql/sqlite/etc
  url      = env("DATABASE_URL")
  // Connection URL moved to `prisma.config.ts` (see https://pris.ly/d/config-datasource)
  // Set `DATABASE_URL` in your environment and reference it from `prisma.config.ts` for Migrate
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String
  photo    String?
  rooms    Room[]
  chats    Chat[]
}

model Room {
  id        Int      @id @default(autoincrement())
  slug      String   @unique
  createdAt DateTime @default(now())
  adminId   String
  admin     User     @relation(fields: [adminId], references: [id])
  chats     Chat[]
}

model Chat {
  id      Int    @id @default(autoincrement())
  message String
  userId  String
  roomId  Int
  room    Room   @relation(fields: [roomId], references: [id])
  user    User   @relation(fields: [userId], references: [id])
}
